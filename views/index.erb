<div class="hero">
  <div class="hero-badge">☀️ Summer 2025</div>
  <h1>Make a <em>splash</em><br>this summer</h1>
  <p>Pick a date and session — spots fill up fast!</p>
</div>

<div class="container">
  <% if params[:cancelled] %>
    <div class="alert alert-warning">
      ⚠️ Payment cancelled — no charge was made. Pick a session below to try again.
    </div>
  <% end %>

  <%# Date picker %>
  <div class="date-picker">
    <% @dates.each do |date| %>
      <button
        class="date-btn <%= date == @selected_date ? 'active' : '' %>"
        hx-get="/sessions/availability?date=<%= date %>"
        hx-target="#availability"
        hx-swap="innerHTML"
        onclick="setSelectedDate('<%= date %>')"
      >
        <span class="date-btn-day"><%= date.strftime("%a") %></span>
        <span class="date-btn-num"><%= date.strftime("%-d") %></span>
        <% if date == Date.today %>
          <span class="date-btn-label">Today</span>
        <% end %>
      </button>
    <% end %>
  </div>

  <input type="hidden" id="selected-date" value="<%= @selected_date %>">

  <div id="availability">
    <%= erb :availability, layout: false %>
  </div>

  <div hx-get="/bookings/cleanup"
       hx-trigger="every 30s"
       hx-swap="none">
  </div>
</div>

<script>
  function setSelectedDate(date) {
    document.getElementById("selected-date").value = date;
    document.querySelectorAll(".date-btn").forEach(b => b.classList.remove("active"));
    event.currentTarget.classList.add("active");
  }
</script>