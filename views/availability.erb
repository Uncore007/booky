<div class="sessions-grid">
  <% @sessions.each do |s| %>
    <% taken = s[:capacity] - s[:spots_remaining] %>
    <% pct_taken = (taken.to_f / s[:capacity] * 100).round %>

    <div class="session-card <%= s[:spots_remaining] == 0 ? 'sold-out' : '' %>">
      <div class="session-time"><%= s[:name] %></div>

      <div class="session-meta">
        <div class="session-spots">
          <% if s[:spots_remaining] == 0 %>
            Sold out
          <% elsif s[:spots_remaining] <= 10 %>
            🔥 Only <%= s[:spots_remaining] %> left
          <% else %>
            <%= s[:spots_remaining] %> spots left
          <% end %>
        </div>
        <div class="spots-bar">
          <div class="spots-fill" style="width:<%= pct_taken %>%"></div>
        </div>
      </div>

      <% if s[:spots_remaining] > 0 %>
        <button class="btn btn-primary"
          hx-get="/sessions/<%= s[:id] %>/book?date=<%= @selected_date %>"
          hx-target="#booking-modal-content"
          hx-swap="innerHTML"
          onclick="document.getElementById('booking-modal').classList.add('open')">
          Book →
        </button>
      <% else %>
        <span class="sold-out-label">Sold out</span>
      <% end %>
    </div>
  <% end %>
</div>

<div id="booking-modal" class="modal-backdrop"
     onclick="if(event.target===this) this.classList.remove('open')">
  <div class="modal">
    <button class="btn btn-ghost modal-close"
            onclick="document.getElementById('booking-modal').classList.remove('open')">✕</button>
    <div id="booking-modal-content"></div>
  </div>
</div>