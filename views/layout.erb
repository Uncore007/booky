<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Water Park Tickets</title>
  <script src="https://unpkg.com/htmx.org@1.9.10"></script>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,700;1,700&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --navy:   #0A3D62;
      --aqua:   #00B4D8;
      --coral:  #FF6B6B;
      --yellow: #FFD60A;
      --sand:   #FFF8F0;
      --white:  #FFFFFF;
      --text:   #1a2e3b;
      --muted:  #6b8899;
      --radius: 16px;
      --shadow: 0 8px 32px rgba(10,61,98,0.12);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: "Nunito", sans-serif;
      background: var(--sand);
      color: var(--text);
      min-height: 100vh;
    }

    /* ---- Hero header ---- */
    .hero {
      background: var(--navy);
      padding: 3rem 2rem 5rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .hero::after {
      content: "";
      position: absolute;
      bottom: -2px;
      left: 0;
      right: 0;
      height: 60px;
      background: var(--sand);
      clip-path: ellipse(55% 100% at 50% 100%);
    }

    .hero-badge {
      display: inline-block;
      background: var(--yellow);
      color: var(--navy);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.3rem 0.9rem;
      border-radius: 999px;
      margin-bottom: 1rem;
    }

    .hero h1 {
      font-family: "Fraunces", serif;
      font-size: clamp(2rem, 5vw, 3.2rem);
      color: var(--white);
      line-height: 1.1;
      margin-bottom: 0.75rem;
    }

    .hero h1 em {
      color: var(--aqua);
      font-style: italic;
    }

    .hero p {
      color: rgba(255,255,255,0.7);
      font-size: 1.05rem;
      max-width: 400px;
      margin: 0 auto;
    }

    /* ---- Main content ---- */
    .container {
      max-width: 680px;
      margin: 0 auto;
      padding: 2rem 1.5rem 4rem;
    }

    /* ---- Alert banners ---- */
    .alert {
      padding: 1rem 1.25rem;
      border-radius: var(--radius);
      margin-bottom: 1.5rem;
      font-weight: 600;
      font-size: 0.95rem;
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .alert-warning {
      background: #FFF3CD;
      border: 1.5px solid #FFD60A;
      color: #7d5a00;
    }
    .alert-error {
      background: #FDECEA;
      border: 1.5px solid #FF6B6B;
      color: #9b1c1c;
    }

    /* ---- Session cards ---- */
    .sessions-grid {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .session-card {
      background: var(--white);
      border-radius: var(--radius);
      padding: 1.25rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: var(--shadow);
      border: 1.5px solid transparent;
      transition: border-color 0.2s, transform 0.2s;
      gap: 1rem;
    }

    .session-card:hover {
      border-color: var(--aqua);
      transform: translateY(-2px);
    }

    .session-card.sold-out {
      opacity: 0.6;
    }

    .session-time {
      font-family: "Fraunces", serif;
      font-size: 1.4rem;
      color: var(--navy);
      white-space: nowrap;
    }

    .session-meta {
      flex: 1;
      padding-left: 1rem;
    }

    .session-spots {
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .spots-bar {
      height: 5px;
      background: #e8f4f8;
      border-radius: 99px;
      margin-top: 0.4rem;
      overflow: hidden;
    }

    .spots-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--aqua), var(--navy));
      border-radius: 99px;
      transition: width 0.4s ease;
    }

    /* ---- Buttons ---- */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.65rem 1.4rem;
      border-radius: 999px;
      font-family: "Nunito", sans-serif;
      font-weight: 700;
      font-size: 0.95rem;
      cursor: pointer;
      border: none;
      transition: transform 0.15s, box-shadow 0.15s;
      white-space: nowrap;
    }

    .btn:active { transform: scale(0.97); }

    .btn-primary {
      background: var(--coral);
      color: var(--white);
      box-shadow: 0 4px 14px rgba(255,107,107,0.35);
    }

    .btn-primary:hover {
      box-shadow: 0 6px 20px rgba(255,107,107,0.45);
      transform: translateY(-1px);
    }

    .btn-secondary {
      background: var(--navy);
      color: var(--white);
    }

    .btn-ghost {
      background: transparent;
      color: var(--muted);
      padding: 0.4rem 0.8rem;
      font-size: 1.1rem;
    }

    .btn-ghost:hover { color: var(--navy); }

    .sold-out-label {
      font-weight: 700;
      font-size: 0.85rem;
      color: var(--coral);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    /* ---- Modal ---- */
    .modal-backdrop {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(10,61,98,0.55);
      backdrop-filter: blur(4px);
      justify-content: center;
      align-items: center;
      z-index: 1000;
      padding: 1rem;
    }

    .modal-backdrop.open { display: flex; }

    .modal {
      background: var(--white);
      border-radius: 24px;
      padding: 2rem;
      width: 100%;
      max-width: 420px;
      position: relative;
      box-shadow: 0 24px 64px rgba(10,61,98,0.25);
      animation: slideUp 0.25s ease;
    }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .modal-close {
      position: absolute;
      top: 1rem;
      right: 1rem;
    }

    /* ---- Booking form ---- */
    .modal-session-tag {
      display: inline-block;
      background: #E8F7FB;
      color: var(--navy);
      font-weight: 700;
      font-size: 0.8rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.3rem 0.8rem;
      border-radius: 999px;
      margin-bottom: 0.75rem;
    }

    .modal h2 {
      font-family: "Fraunces", serif;
      font-size: 1.6rem;
      color: var(--navy);
      margin-bottom: 0.25rem;
    }

    .modal-price {
      font-size: 0.9rem;
      color: var(--muted);
      margin-bottom: 1.5rem;
      font-weight: 600;
    }

    .form-group {
      margin-bottom: 1rem;
    }

    .form-group label {
      display: block;
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--muted);
      margin-bottom: 0.4rem;
    }

    .form-group input {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 1.5px solid #dde8ef;
      border-radius: 10px;
      font-family: "Nunito", sans-serif;
      font-size: 0.95rem;
      color: var(--text);
      transition: border-color 0.2s;
      background: var(--sand);
    }

    .form-group input:focus {
      outline: none;
      border-color: var(--aqua);
      background: var(--white);
    }

    .form-submit-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: 1.5rem;
      gap: 1rem;
    }

    .form-total {
      font-family: "Fraunces", serif;
      font-size: 1.4rem;
      color: var(--navy);
    }

    .form-total span {
      font-family: "Nunito", sans-serif;
      font-size: 0.75rem;
      color: var(--muted);
      font-weight: 600;
      display: block;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    /* ---- Confirmation page ---- */
    .confirmation {
      text-align: center;
      padding: 3rem 1rem;
    }

    .confirmation-icon {
      font-size: 4rem;
      margin-bottom: 1rem;
      animation: pop 0.4s cubic-bezier(0.175,0.885,0.32,1.275);
    }

    @keyframes pop {
      from { transform: scale(0); }
      to   { transform: scale(1); }
    }

    .confirmation h1 {
      font-family: "Fraunces", serif;
      font-size: 2.2rem;
      color: var(--navy);
      margin-bottom: 0.5rem;
    }

    .confirmation p {
      color: var(--muted);
      font-size: 1rem;
      margin-bottom: 0.4rem;
    }

    .confirmation-card {
      background: var(--white);
      border-radius: var(--radius);
      padding: 1.5rem;
      margin: 2rem auto;
      max-width: 360px;
      box-shadow: var(--shadow);
      text-align: left;
    }

    .confirmation-card-row {
      display: flex;
      justify-content: space-between;
      padding: 0.5rem 0;
      border-bottom: 1px solid #eef3f6;
      font-size: 0.95rem;
    }

    .confirmation-card-row:last-child { border-bottom: none; }
    .confirmation-card-row strong { color: var(--navy); }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      color: var(--muted);
      font-weight: 700;
      font-size: 0.9rem;
      text-decoration: none;
      margin-top: 1rem;
    }

    .back-link:hover { color: var(--navy); }

    /* ---- Date picker ---- */
    .date-picker {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding-bottom: 1rem;
    margin-bottom: 1.5rem;
    scrollbar-width: none;
    }

    .date-picker::-webkit-scrollbar { display: none; }

    .date-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.6rem 0.9rem;
    border-radius: 12px;
    border: 1.5px solid #dde8ef;
    background: var(--white);
    cursor: pointer;
    min-width: 56px;
    transition: all 0.15s;
    font-family: "Nunito", sans-serif;
    gap: 0.1rem;
    }

    .date-btn:hover {
    border-color: var(--aqua);
    transform: translateY(-2px);
    }

    .date-btn.active {
    background: var(--navy);
    border-color: var(--navy);
    color: var(--white);
    box-shadow: 0 4px 14px rgba(10,61,98,0.25);
    }

    .date-btn-day {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.6;
    }

    .date-btn.active .date-btn-day { opacity: 0.7; }

    .date-btn-num {
    font-family: "Fraunces", serif;
    font-size: 1.3rem;
    line-height: 1;
    }

    .date-btn-label {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--coral);
    }

    .date-btn.active .date-btn-label { color: var(--yellow); }

    
  </style>
</head>
<body>
  <%= yield %>
</body>
</html>