<!-- views/book_form.erb -->
<h2>Book: <%= @session[:name] %></h2>
<p><%= @spots_remaining %> spots remaining · $25 per ticket</p>

<form action="/bookings" method="post">
  <input type="hidden" name="session_id" value="<%= @session[:id] %>">

  <label>Name<br>
    <input type="text" name="name" required style="width:100%; margin-top:4px;">
  </label><br><br>

  <label>Email<br>
    <input type="email" name="email" required style="width:100%; margin-top:4px;">
  </label><br><br>

  <label>Tickets<br>
    <input type="number" name="quantity" value="1" min="1" max="<%= @spots_remaining %>" required style="width:60px; margin-top:4px;">
  </label><br><br>

  <button type="submit" style="background:#0077cc; color:white; padding:0.6rem 1.5rem; border:none; border-radius:6px; cursor:pointer;">
    Confirm Booking →
  </button>
</form>